{
  "name": "site-spec",
  "version": "0.3.0",
  "description": "Audit any website’s invisible foundation (SEO, accessibility, privacy, structured data, AI searchability) and auto-fix what’s broken.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Aria Han",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ariaxhan/site-spec.git",
    "directory": "packages/cli"
  },
  "bin": {
    "site-spec": "./dist/cli.mjs"
  },
  "scripts": {
    "build": "esbuild src/cli.ts --bundle --platform=node --format=esm --banner:js='#!/usr/bin/env node' --outfile=dist/cli.mjs && chmod +x dist/cli.mjs",
    "typecheck": "tsc -b",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@site-spec/core": "*",
    "esbuild": "^0.25.0"
  },
  "keywords": [
    "website-audit",
    "website-fixer",
    "seo-audit",
    "ai-searchability",
    "llms-txt",
    "robots-txt",
    "structured-data",
    "accessibility",
    "cli"
  ],
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  }
}
