{
  "env": [],
  "cookies": [],
  "analytics": {
    "provider": "none"
  },
  "forms": [
    {
      "id": "quoteForm",
      "intent": "request a catering quote",
      "endpoint": "mailto:hello@sunnytable.example",
      "method": "mailto",
      "fields": [
        {
          "name": "name",
          "type": "text",
          "required": true
        },
        {
          "name": "phone",
          "type": "tel",
          "required": true
        },
        {
          "name": "email",
          "type": "email",
          "required": false
        },
        {
          "name": "date",
          "type": "text",
          "required": false
        },
        {
          "name": "guests",
          "type": "select",
          "required": false
        },
        {
          "name": "occasion",
          "type": "select",
          "required": false
        },
        {
          "name": "notes",
          "type": "textarea",
          "required": false
        }
      ],
      "spam": "none"
    }
  ]
}
